# Database (Postgres)
DATABASE_URL=postgresql://postgres:mysecretpassword@127.0.0.1:5432/logo_service?sslmode=disable
DATABASE_MAX_CONNECTIONS=50

# Jina API
JINA_API_KEY=
JINA_EMBEDDING_MODEL=jina-clip-v2
JINA_EMBEDDINGS_URL=https://api.jina.ai/v1/embeddings
JINA_BATCH_SIZE=8
JINA_TIMEOUT_SECONDS=30
JINA_USE_PROXY=true

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=logo_reference_vectors
QDRANT_USE_PROXY=false

# S3/MinIO
S3_ENDPOINT_URL=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=bucket0
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_SSL=false
S3_USE_PROXY=false

# LLM
LLM_BASE_URL=
LLM_API_KEY=

# models
MODEL_IMAGE_DETAIL=

# Image Downloads
DOWNLOAD_USE_PROXY=false

GROUNDING_DINO_MODEL_ID=IDEA-Research/grounding-dino-tiny
GROUNDING_DINO_DEVICE=cpu
DETECTION_PROMPT=logo . brand logo . emblem . trademark . label
DETECTION_BOX_THRESHOLD=0.25
DETECTION_TEXT_THRESHOLD=0.20
DETECTION_TOP_K=5

CLASSIFICATION_TOP_K=8 # return the top K candidates for each qdrant search
CLASSIFICATION_MATCH_THRESHOLD=0.45 # top score must be greater than this threshold
CLASSIFICATION_MARGIN_THRESHOLD=0.03 # top score must be greater than the second score by this margin
CLASSIFICATION_FALLBACK_TO_FULL_IMAGE=true
